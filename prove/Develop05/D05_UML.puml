@startuml
abstract class Goal {
  # _name : string
  # _description : string
  # _points : int
  --
  + Goal(name : string, description : string, points : int)
  + GetName() : string
  + GetPoint() : int
  + {abstract} RecordEvent() : void
  + GetDetailsString() : virtual string
  + GetStringRepresentation() : virtual string
  + {abstract} IsComplete() : bool
  + virtual GetDetailsString() : string
  + virtual GetStringRepresentation() : string
}

class SimpleGoal {
  - _isComplete : bool
  + RecordEvent() : void
  + IsComplete() : bool
}

class ChecklistGoal {
  - _amountCompleted : int
  - _target : int
  - _bonus : int
  + RecordEvent() : void
  + IsComplete() : bool
}

class GoalManager {
  - _goals : List<Goal>
  - _score : int
  + Start() : void
  + DisplayPlayerInfo() : void
  + CreateGoal() : void
  + RecordEvent() : void
  + SaveGoals() : void
  + LoadGoals() : void
}

Goal <|-- SimpleGoal
Goal <|-- EternalGoal
Goal <|-- ChecklistGoal
GoalManager o-- Goal
@enduml